# ─── PracticeFlow Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# The app works fully without any API keys (uses mock AI responses by default).

# ─── AI Integration (optional) ───────────────────────────────────────────────
# If set, the Netlify functions will use real AI for practice generation.
# Leave blank to use high-quality mock responses.

# OpenAI (for GPT-4 practice generation)
# VITE_AI_API_KEY=your_openai_key_here
# OPENAI_API_KEY=your_openai_key_here

# Or Anthropic (for Claude-powered generation)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── App Config (optional) ────────────────────────────────────────────────────
# VITE_APP_TITLE=PracticeFlow
# VITE_APP_URL=https://your-app.netlify.app

# ─── Analytics (optional) ────────────────────────────────────────────────────
# VITE_POSTHOG_KEY=your_posthog_key
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
